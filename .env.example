# Copy to .env and fill in values

HF_TOKEN=
FAL_KEY=

# Optional: Hugging Face Inference provider (default: fal-ai)
# HF_INFERENCE_PROVIDER=fal-ai

# --- Auth (Telegram Mini App + TON wallet) ---
# Create a bot via @BotFather, then set the Web App URL to your frontend.
TELEGRAM_BOT_TOKEN=
JWT_SECRET=
# Set to 0 to allow generation without login (local dev only)
AUTH_REQUIRED=1

# --- Database (Docker Compose uses Postgres) ---
# DATABASE_URL=postgresql://wan:wan@localhost:5432/wan_video

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=wan-video
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Leave empty to serve files via API proxy (/api/files/...). Set for direct MinIO URLs:
# MINIO_PUBLIC_URL=http://localhost:9000/wan-video

# --- Docker Compose ---
WEB_PORT=3000
POSTGRES_USER=wan
POSTGRES_PASSWORD=wan
POSTGRES_DB=wan_video
